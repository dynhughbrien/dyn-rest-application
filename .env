# Dynatrace MCP Configuration
# Fill in your actual credentials from your Dynatrace environment

# OAuth Client ID from Dynatrace
OAUTH_CLIENT_ID=your_oauth_client_id_here

# OAuth Client Secret from Dynatrace
OAUTH_CLIENT_SECRET=your_oauth_client_secret_here

# Dynatrace Environment URL (e.g., https://id.domain.apps.dynatracelabs.com)
DT_ENVIRONMENT=https://your_environment_url_here

